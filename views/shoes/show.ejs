<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= shoe.brand %> <%= shoe.model %>
    </title>
</head>
<body>

    <%- include('../partials/_navbar.ejs', { title: shoe.brand + " " + shoe.model }) %>

    <main class="main-content">
        <section class="detail-shell">
            <article class="detail-card">
                
                <h1 class="page-title"><%= shoe.brand %> <%= shoe.model %></h1>
                <div class="spec-grid">
                    <div class="spec-item">
                        <span class="spec-label">Brand</span>
                        <span class="spec-value"><%= shoe.brand %></span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Model</span>
                        <span class="spec-value"><%= shoe.model %></span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Colorway</span>
                        <span class="spec-value"><%= shoe.colorway %></span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Retail Price</span>
                        <span class="spec-value">$<%= shoe.retailPrice %></span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Size</span>
                        <span class="spec-value"><%= shoe.size %></span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Deadstock</span>
                        <span class="spec-value"><%= shoe.isDeadstock ? "Yes" : "No" %></span>
                    </div>
                </div>

                <div class="detail-copy">
                    <span class="spec-label">Description</span>
                    <p><%= shoe.description %></p>
                </div>

                <div class="shoe-actions">
                    <a class="btn-primary" href="/shoes/<%= shoe._id %>/edit">
                        Edit <%= shoe.brand %> <%= shoe.model %>
                    </a>

                    <a class="btn-danger" href="/shoes/<%= shoe._id %>/confirm_delete">
                        Delete <%= shoe.brand %> <%= shoe.model %>
                    </a>

                    <button class="btn-secondary" type="button" onclick="window.history.back()">Go Back</button>
                </div>
            </article>

            <aside class="image-card">
                <img class="detail-image" src="<%= shoe.imageUrl %>" alt="<%= shoe.brand %> <%= shoe.model %>">
            </aside>
        </section>
    </main>

</body>
</html>