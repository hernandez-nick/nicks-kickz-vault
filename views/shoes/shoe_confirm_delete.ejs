<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Delete</title>
</head>

<body>

    <%- include('../partials/_navbar.ejs', { title: "Delete " + shoe.brand + " " + shoe.model }) %>

    <main class="main-content">
        <section class="confirm-card">
            
            <h1 class="page-title">Confirm Delete</h1>
            <p class="confirm-copy">Are you sure you want to delete the <strong><%= shoe.brand %> <%= shoe.model %></strong> from your vault?</p>

            <div class="shoe-actions">
                <form action="/shoes/<%= shoe._id %>?_method=DELETE" method="POST">
                    <button class="btn-danger" type="submit">Yes, Delete <%= shoe.brand %> <%= shoe.model %></button>
                </form>

                <a class="btn-secondary" href="/shoes/<%= shoe._id %>/">Cancel</a>
            </div>
        </section>
    </main>

</body>

</html>
