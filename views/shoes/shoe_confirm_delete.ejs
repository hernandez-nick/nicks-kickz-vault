<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Delete</title>
</head>

<body>

    <%- include('../partials/_navbar.ejs') %>

        <h1>Confirm Delete</h1>

        <p>Are you sure you want to delete the shoe: <em style="color: <%= shoe.color %>;">
                <%= shoe.name %>
            </em>?</p>
        <div class="shoe-actions">
            <form class="delete-form" action="/shoes/<%= shoe._id %>?_method=DELETE" method="POST">
                <button class="delete-button" type="submit">Delete <%= shoe.name %></button>
            </form>
        </div>

        <button onclick="window.history.back()">No, Go Back</button>
        
</body>

</html>