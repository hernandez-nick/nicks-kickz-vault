<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editing <%= shoe.brand %> <%= shoe.model %></title>
</head>

<body>

    <%- include('../partials/_navbar.ejs', { title: "Editing " + shoe.brand + " " + shoe.model }) %>

    <main class="main-content">
        <section class="form-card">
            <p class="detail-eyebrow">Edit Pair</p>
            <h1 class="page-title">Edit <%= shoe.brand %> <%= shoe.model %></h1>

            <form class="shoe-form" action="/shoes/<%= shoe._id %>?_method=PUT" method="POST">
                <% if(typeof(message) !=="undefined" ) { %>
                    <p class="form-error"><%= message %></p>
                <% } %>

                <div class="form-grid">
                    <div class="field-group">
                        <label for="model">Model</label>
                        <input type="text" name="model" id="model" required value="<%= shoe.model %>" />
                    </div>

                    <div class="field-group">
                        <label for="brand">Brand</label>
                        <input type="text" name="brand" id="brand" required value="<%= shoe.brand %>" />
                    </div>

                    <div class="field-group">
                        <label for="colorway">Colorway</label>
                        <input type="text" name="colorway" id="colorway" required value="<%= shoe.colorway %>" />
                    </div>

                    <div class="field-group">
                        <label for="retailPrice">Retail Price</label>
                        <input type="number" name="retailPrice" id="retailPrice" required value="<%= shoe.retailPrice %>" />
                    </div>

                    <div class="field-group">
                        <label for="size">Size</label>
                        <input type="number" name="size" id="size" required value="<%= shoe.size %>" />
                    </div>

                    <div class="field-group field-group-checkbox">
                        <label for="isDeadstock">Deadstock</label>
                        <input type="checkbox" name="isDeadstock" id="isDeadstock" <% if (shoe.isDeadstock) { %>checked<% } %> />
                    </div>

                    <div class="field-group field-group-full">
                        <label for="imageUrl">Image URL</label>
                        <input type="url" name="imageUrl" id="imageUrl" required value="<%= shoe.imageUrl %>" />
                    </div>

                    <div class="field-group field-group-full">
                        <label for="description">Description</label>
                        <textarea name="description" id="description" placeholder="Please enter a description of 100 characters or less." maxlength="100" required><%= shoe.description %></textarea>
                    </div>
                </div>

                <div class="shoe-actions">
                    <button class="btn-primary" type="submit">Update</button>
                    <button class="btn-secondary" type="button" onclick="window.history.back()">Go Back</button>
                </div>
            </form>
        </section>
    </main>

</body>

</html>