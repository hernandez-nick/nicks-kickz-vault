<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vault</title>
</head>
<body>
    
    <%- include('../partials/_navbar.ejs', { title: "Vault" }) %>

    <main class="main-content">
        <a href="/shoes/new" class="btn-primary">+ Add New Pair</a>

        <% if (shoes.length === 0) { %>
            <p class="empty-msg">No shoes added yet.</p>
        <% } else { %>
            <div class="shoe-grid">
                <% shoes.forEach((shoe) => { %>
                    <div class="shoe-card">
                        <p class="shoe-brand"><%= shoe.brand %></p>
                        <p class="shoe-model"><%= shoe.model %></p>
                        <img src="<%= shoe.imageUrl %>" alt="<%= shoe.brand %> <%= shoe.model %> shoe" class="shoe-thumb">
                        <a href="/shoes/<%= shoe._id %>" class="btn-view">👀 View Details</a>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

</body>
</html>
