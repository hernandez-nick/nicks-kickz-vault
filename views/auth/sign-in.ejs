<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
</head>

<body>

    <%- include('../partials/_navbar.ejs', { title: "Sign In" }) %>

    <main class="main-content auth-shell">
        <section class="form-card auth-card">
            
            <h1 class="page-title">Sign in to your account</h1>
            
            <form class="shoe-form auth-form" action="/auth/sign-in" method="POST">
                <% if (typeof message !== 'undefined') { %>
                    <p class="form-error"><%= message %></p>
                <% } %>

                <div class="form-grid auth-grid">
                    <div class="field-group field-group-full">
                        <label for="username">Username</label>
                        <input type="text" name="username" id="username" required placeholder="Enter your username" />
                    </div>
                    <div class="field-group field-group-full">
                        <label for="password">Password</label>
                        <input type="password" name="password" id="password" required placeholder="Enter your password" />
                    </div>
                </div>

                <div class="shoe-actions">
                    <button class="btn-primary" type="submit">Sign In</button>
                    <a class="btn-secondary" href="/auth/sign-up">Create Account</a>
                </div>
            </form>
        </section>
    </main>
</body>

</html>