<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error Page</title>
</head>
<body>

    <%- include('partials/_navbar.ejs', { title: "Error" }) %>

    <main class="main-content">
        <section class="confirm-card error-card">
            <h1 class="page-title">Danger, you have encountered an error.</h1>
            <p class="confirm-copy"><strong>Error Message:</strong> <%= message %></p>

            <div class="shoe-actions">
                <button class="btn-secondary" type="button" onclick="window.history.back()">Go Back</button>
                <a class="btn-primary" href="/">Return Home</a>
            </div>
        </section>
    </main>
</body>
</html>