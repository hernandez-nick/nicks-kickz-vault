<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nick's Kickz Vault</title>
</head>
<body>

    <%- include('partials/_navbar.ejs', { title: "Nick's Kickz Vault" }) %>

    <main class="main-content">
        <section class="home-card">
            <h1 class="page-title">Nick's Kickz Vault</h1>
            <p class="home-subtitle">Track your shoe collection!</p>

            <div class="shoe-actions">
                <% if (currentUser) { %>
                    <a class="btn-primary" href="/shoes">Open Vault</a>
                    <a class="btn-secondary" href="/shoes/new">Add New Pair</a>
                <% } else { %>
                    <a class="btn-primary" href="/auth/sign-in">Sign In</a>
                    <a class="btn-secondary" href="/auth/sign-up">Sign Up</a>
                <% } %>
            </div>
        </section>
    </main>

</body>
</html>